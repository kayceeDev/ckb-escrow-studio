{
  "name": "@ckb-escrow/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Escrow protocol SDK for CKB, intended to be used on top of CCC",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
